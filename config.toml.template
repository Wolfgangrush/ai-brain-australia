# AI Brain — Australia · config.toml
# Generated by setup.sh. Customize as needed.

[jurisdiction]
country = "Australia"
citation_format = "AGLC"                               # Australian Guide to Legal Citation
court_hierarchy = "../australia/_court_hierarchy.json"  # path to a JSON map of courts
bar_rules = "../australia/_bar_rules.md"                # path to bar-rules markdown (state Bar associations)
timezone = "Australia/Sydney"                           # configurable per state, DST-aware

[paths]
statute_corpus = "../australia/_statute_corpus/"
drafting_corpus = "../australia/_drafting_data/"
audit_log_dir = "~/.ailawfirm_australia/audit_logs/"
matter_root = "~/.ailawfirm_australia/matters/"

[llm]
provider = "claude"                                      # v0.1 only supports claude
# In v0.3+: "openai" · "gemini_paid" · "ollama" · "byom"
